rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Card player rooms: any signed-in user (use Anonymous auth) can read/write a room doc.
    match /cardPlayerRooms/{roomId} {
      allow read, write: if request.auth != null && roomId.size() >= 4 && roomId.size() <= 64;
    }
  }
}
