# Copy values into your shell (or a secure secret store). Node does not load this file automatically.
#
# Linux (Let's Encrypt):
# SSL_KEY_PATH=/etc/letsencrypt/live/relay.example.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/relay.example.com/fullchain.pem
#
# Windows (adjust paths):
# SSL_KEY_PATH=C:\certs\privkey.pem
# SSL_CERT_PATH=C:\certs\fullchain.pem

SSL_KEY_PATH=
SSL_CERT_PATH=
SERVER_PUBLIC_HOST=relay.example.com
PORT=8765
